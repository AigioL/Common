<Project>

	<!-- 👇 Windows Only -->
	<ItemGroup>
		<PackageVersion Include="Microsoft.Windows.CsWin32" Version="0.3.183" />
		<PackageVersion Include="System.Management" Version="9.0.8" />
		<PackageVersion Include="WmiLight" Version="6.14.0" />
	</ItemGroup>

	<!-- 👇 WinUI3 -->
	<ItemGroup>
		<PackageVersion Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.4654" />
		<PackageVersion Include="Microsoft.WindowsAppSDK" Version="1.7.250606001" />
	</ItemGroup>

	<!-- 👇 日志 -->
	<ItemGroup>
		<PackageVersion Include="Microsoft.Extensions.Logging.EventLog" Version="9.0.8" />
		<PackageVersion Include="Microsoft.Extensions.Logging.Console" Version="9.0.8" />
		<PackageVersion Include="NLog" Version="6.0.3" />
		<PackageVersion Include="NLog.Web.AspNetCore" Version="6.0.3" />
	</ItemGroup>

	<!-- 👇 xunit 单元测试 -->
	<ItemGroup>
		<PackageVersion Include="coverlet.collector" Version="6.0.4" />
		<PackageVersion Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
		<PackageVersion Include="xunit.v3" Version="3.0.0" />
		<PackageVersion Include="xunit.runner.visualstudio" Version="3.1.3" />
	</ItemGroup>

	<!-- 👇 哈希算法 -->
	<ItemGroup>
		<PackageVersion Include="System.IO.Hashing" Version="9.0.8" />
	</ItemGroup>

	<!-- 👇 JsonWebToken -->
	<ItemGroup>
		<PackageVersion Include="Microsoft.IdentityModel.JsonWebTokens" Version="8.13.1" />
		<PackageVersion Include="System.IdentityModel.Tokens.Jwt" Version="8.13.1" />
	</ItemGroup>

	<!-- 👇 可回收内存流 -->
	<ItemGroup>
		<PackageVersion Include="Microsoft.IO.RecyclableMemoryStream" Version="3.0.1" />
	</ItemGroup>

	<!-- 👇 EF Core -->
	<ItemGroup>
		<PackageVersion Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" Version="9.0.8" />
		<PackageVersion Include="Microsoft.EntityFrameworkCore" Version="9.0.8" />
		<PackageVersion Include="Microsoft.EntityFrameworkCore.Relational" Version="9.0.8" />
		<PackageVersion Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.4" />
	</ItemGroup>

	<!-- 👇 序列化 -->
	<ItemGroup>
		<PackageVersion Include="MemoryPack" Version="1.21.4" />
		<PackageVersion Include="MemoryPack.Streaming" Version="1.21.4" />
	</ItemGroup>

	<!-- 👇 OpenApi -->
	<ItemGroup>
		<PackageVersion Include="Microsoft.AspNetCore.OpenApi" Version="9.0.8" />
		<PackageVersion Include="Scalar.AspNetCore" Version="2.6.9" />
	</ItemGroup>

	<!-- 👇 ExternalLogin 外部账号登录 -->
	<ItemGroup>
		<PackageVersion Include="Microsoft.AspNetCore.Authentication.MicrosoftAccount" Version="9.0.8" />
		<PackageVersion Include="Microsoft.AspNetCore.Authentication.Facebook" Version="9.0.8" />
		<PackageVersion Include="Microsoft.AspNetCore.Authentication.Twitter" Version="9.0.8" />
		<PackageVersion Include="Microsoft.AspNetCore.Authentication.Google" Version="9.0.8" />
		<PackageVersion Include="AspNet.Security.OAuth.Apple" Version="9.4.0" />
		<PackageVersion Include="AspNet.Security.OAuth.Weixin" Version="9.4.0" />
		<PackageVersion Include="AspNet.Security.OAuth.QQ" Version="9.4.0" />
		<PackageVersion Include="AspNet.Security.OAuth.Alipay" Version="9.4.0" />
		<PackageVersion Include="AspNet.Security.OAuth.Feishu" Version="9.4.0" />
	</ItemGroup>

	<!-- 👇 Redis -->
	<ItemGroup>
		<PackageVersion Include="Aspire.Hosting.Redis" Version="9.4.0" />
		<PackageVersion Include="Aspire.StackExchange.Redis.OutputCaching" Version="9.4.0" />
		<PackageVersion Include="Aspire.StackExchange.Redis.DistributedCaching" Version="9.4.1" />
	</ItemGroup>

	<!-- 👇 Razor -->
	<ItemGroup>
		<PackageVersion Include="RazorSlices" Version="0.9.5" />
	</ItemGroup>

</Project>